bool isAnagram(string s, string t) {
          vector<int> freq(26 , 0);
        if(s.size() != t.size()) return false;

         for(int i=0;i<s.size();i++){
            freq[s[i]-'a']++;
            freq[t[i]-'a']--;
         }
         for(int j=0;j<26;j++){
            if(freq[j]!=0) return false;
         }
         return true;
        
    }
