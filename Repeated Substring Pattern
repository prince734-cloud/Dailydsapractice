bool repeatedSubstringPattern(string s) {
        int n = s.size();
        for(int i= 1;i<=n/2;i++){
            if(n%i==0){
                string pattern="";
                int repeat=n/i;
                for(int j=0;j<repeat;j++){
                    pattern+=s.substr(0,i);
                }
                if(s==pattern) return true;

                
            }

        }
        return  false;
        
    }
