 ListNode* oddEvenList(ListNode* head) {

        if(head==NULL || head->next==NULL) return head;

        ListNode* odd =head;
        ListNode* even = head->next;
         ListNode* evenhead = head->next;


        while(even!=NULL && even->next!=NULL ){
            odd->next=even->next;
            odd=even->next;
            even->next=odd->next;
            even=even->next;


        }
         odd->next=evenhead;

         return head;
        
    }
