int numSubarrayProductLessThanK(vector<int>& nums, int k) {
       if(k<=1) return 0;
        int prd =1;
        int i=0 ;
        int count=0;
        for(int j=0;j<nums.size();j++){
            prd*=nums[j];

            while(prd>=k){
                prd /=nums[i];
                i++;
            }
            count+=(j-i+1);
        }
        return count;
    }
